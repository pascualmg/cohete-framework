{
    "name": "cohete/framework",
    "description": "Async PHP framework built on ReactPHP and RxPHP",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "evenement/evenement": "^3.0",
        "fig/http-message-util": "^1",
        "for/http-middleware-psr15-adapter": "^2.0",
        "middlewares/client-ip": "^2.0",
        "monolog/monolog": "^3.5",
        "nikic/fast-route": "^1.3",
        "php-di/php-di": "^7.0",
        "react/event-loop": "^1.5",
        "react/http": "^1.9",
        "react/promise": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.12"
    },
    "autoload": {
        "psr-4": {
            "Cohete\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Cohete\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "analyse": "vendor/bin/phpstan analyse"
    },
    "authors": [
        {
            "name": "Pascual Munoz",
            "homepage": "https://pascualmg.dev"
        }
    ],
    "minimum-stability": "stable",
    "config": {
        "sort-packages": true
    }
}
